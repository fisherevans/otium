# otium-server config (12-factor). Copy to .env for local, or set in the k8s
# Secret for prod. Auth is required: set OTIUM_DEV_USER (local) OR the
# OTIUM_OIDC_* block (prod). Setting neither is a startup error.

PORT=8080
OTIUM_DB_PATH=./data/otium.db
OTIUM_FETCH_INTERVAL_MIN=30        # 0 = fetch on demand only

# --- local dev: bypass auth, auto-login as this user (NEVER in prod) ---
OTIUM_DEV_USER=fisher

# --- prod: confidential OIDC client of auth.fisher.sh (leave DEV_USER unset) ---
# OTIUM_OIDC_ISSUER=https://auth.fisher.sh
# OTIUM_OIDC_INTERNAL_URL=http://hydra-public.auth.svc.cluster.local:4444
# OTIUM_OIDC_CLIENT_ID=otium
# OTIUM_OIDC_CLIENT_SECRET=...
# OTIUM_OIDC_REDIRECT_URL=https://otium.fisher.sh/auth/callback
# OTIUM_OIDC_SCOPES=openid profile email groups offline_access
# OTIUM_OIDC_ALLOWED_GROUPS=admins
# OTIUM_SESSION_SECRET=...          # HMAC key for the OIDC flow cookie
# OTIUM_INGEST_USER=<fisher-oidc-subject>   # who the background loop refreshes for
